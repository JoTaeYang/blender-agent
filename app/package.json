{
  "name": "reforge",
  "productName": "Reforge",
  "version": "0.1.0",
  "description": "Reforge — AI-assisted game-ready 3D asset pipeline (retopology, UV optimization, export)",
  "main": "out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "brand:dev": "node scripts/brand-dev-electron.mjs",
    "predev": "node scripts/brand-dev-electron.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test:integration": "tsx --tsconfig tsconfig.node.json --test test/integration.test.ts",
    "start": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "co.thakicloud.reforge",
    "productName": "Reforge",
    "directories": {
      "output": "release",
      "buildResources": "buildResources"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "../worker",
        "to": "pysrc/worker",
        "filter": [
          "**/*.py",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "../uv_agent",
        "to": "pysrc/uv_agent",
        "filter": [
          "**/*.py",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "../chart_uv_agent",
        "to": "pysrc/chart_uv_agent",
        "filter": [
          "**/*.py",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "../artist_uv_agent",
        "to": "pysrc/artist_uv_agent",
        "filter": [
          "**/*.py",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "../transfer_uv_agent",
        "to": "pysrc/transfer_uv_agent",
        "filter": [
          "**/*.py",
          "!**/__pycache__/**"
        ]
      },
      {
        "from": "../retopo_agent",
        "to": "pysrc/retopo_agent",
        "filter": [
          "**/*.py",
          "!**/__pycache__/**"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Graphics"
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
