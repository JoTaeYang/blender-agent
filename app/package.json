{
  "name": "uv-review-app",
  "version": "0.1.0",
  "description": "Electron UV Review App — MVP 0 high-to-low preparation workflow",
  "main": "out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test:integration": "tsx --tsconfig tsconfig.node.json --test test/integration.test.ts",
    "start": "electron-vite preview"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vite": "^5.3.0"
  }
}
